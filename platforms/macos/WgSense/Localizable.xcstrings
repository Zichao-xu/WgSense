            "value" : "This will disconnect WireGuard and delete profile “%1$@”. This cannot be undone."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "این کار WireGuard را قطع می کند و پروفایل را حذف می کند.%1$@این را نمی توان انکار کرد."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WGを切断して現在のprofile「%@」を削除します。この操作は取り消すことができません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WG를 끊고 현재 profile「%@」을 삭제할 예정이며, 이 작업은 취소할 수 없습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "WG будет отключен и текущий профиль \"%@\" будет удален, эта операция не отменяется."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu, WireGuard'ı kesecektir ve profili “%1$@\"Bu geri çekilmez."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tùy chọn này sẽ ngắt kết nối Wire Guard và xoá hồ sơ%1$@Điều này không thể thay đổi được ”."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将断开 WG 并删除当前 profile「%@」，此操作不可撤销。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
